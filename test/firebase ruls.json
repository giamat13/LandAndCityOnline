{
  "rules": {
    "roomActivity": {
      ".read": true,
      "$roomId": {
        ".write": true,
        ".validate": "newData.isNumber()"
      }
    },
    "publicRooms": {
      ".read": true,
      "$roomId": { ".write": true }
    },
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": true
      }
    },
    "dailyStats": {
      "$day": {
        ".read": true,
        "players": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999999"
        }
      }
    },
    "dailyChallenge": {
      "$day": {
        ".read": true,
        "scores": {
          "$playerId": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','score','ts']) && newData.child('score').isNumber() && newData.child('score').val() >= 0 && newData.child('score').val() <= 9999"
          }
        }
      }
    },
    "publicPacks": {
      ".read": true,
      "$packId": {
        ".write": true,
        ".validate": "newData.hasChildren(['name','cats','creator','ts'])"
      }
    },
    "referrals": {
      ".read": true,
      "$refId": {
        "count": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999"
        },
        "name": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "emoji": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length <= 20"
        }
      }
    },
    "adminData": {
      ".read": "auth != null",
      "referrals": {
        ".read": true,
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      },
      "anonStats": {
        "$day": {
          ".write": true
        }
      }
    },
    "weeklyLeaderboard": {
      ".read": true,
      "$week": {
        "$player": {
          ".write": true,
          ".validate": "newData.hasChildren(['name','score','games','ts']) && newData.child('score').isNumber() && newData.child('score').val() >= 0 && newData.child('score').val() <= 999999 && newData.child('games').isNumber() && newData.child('games').val() >= 0 && newData.child('games').val() <= 9999"
        }
      }
    },
    "leaderboardBanned": {
      ".read": true,
      "$playerKey": {
        ".write": true,
        ".validate": "newData.hasChildren(['name','ts','bannedBy']) && newData.child('name').isString() && newData.child('ts').isNumber() && newData.child('bannedBy').isString()"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "profile": {
          "name": {
            ".read": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'"
          }
        }
      }
    },
    "conquest": {
      ".read": true,
      "tiles": {
        "$tileId": {
          ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
          ".validate": "newData.hasChildren(['score','uid','ts']) && newData.child('uid').val() === auth.uid && newData.child('score').isNumber() && newData.child('score').val() >= 0 && newData.child('score').val() <= 99999 && (!data.exists() || newData.child('score').val() > data.child('score').val() || (data.child('allianceId').exists() && newData.child('allianceId').val() === data.child('allianceId').val() && newData.child('score').val() >= data.child('score').val() && root.child('conquest').child('alliances').child(data.child('allianceId').val()).child('members').child(auth.uid).val() === true))"
        }
      },
      "players": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && auth.token.firebase.sign_in_provider !== 'anonymous'",
          ".validate": "newData.hasChildren(['name']) && newData.child('name').isString() && newData.child('name').val().length <= 40"
        }
      },
      "alliances": {
        ".read": true,
        "$aid": {
          ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && ((!data.exists() && newData.child('owner').val() === auth.uid) || (data.exists() && data.child('owner').val() === auth.uid))",
          ".validate": "newData.hasChildren(['name','owner','ts']) && newData.child('name').isString() && newData.child('name').val().length <= 30 && newData.child('owner').isString() && newData.child('ts').isNumber()",
          "name": { ".validate": "newData.isString() && newData.val().length <= 30" },
          "tag": { ".validate": "newData.isString() && newData.val().length <= 5" },
          "color": { ".validate": "newData.isString() && newData.val().length <= 25" },
          "code": { ".validate": "newData.isString() && newData.val().length <= 12" },
          "open": { ".validate": "newData.isBoolean()" },
          "members": {
            "$uid": {
              ".write": "auth != null && $uid === auth.uid && auth.token.firebase.sign_in_provider !== 'anonymous'",
              ".validate": "newData.isBoolean()"
            }
          }
        }
      }
    }
  }
}